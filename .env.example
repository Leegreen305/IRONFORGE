# IRONFORGE Environment Configuration
# Copy this file to .env and populate the values before starting.

# ─── REQUIRED ──────────────────────────────────────────────────────────────
# Anthropic API key. Required for AI-powered COA generation and OPORD production.
# Obtain at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── OPTIONAL — BACKEND ────────────────────────────────────────────────────
# Port for the FastAPI backend. Defaults to 8000.
BACKEND_PORT=8000

# Host binding for uvicorn. Use 0.0.0.0 to expose on all interfaces.
BACKEND_HOST=0.0.0.0

# Log level for uvicorn. Options: critical, error, warning, info, debug, trace.
LOG_LEVEL=info

# ─── OPTIONAL — FRONTEND ───────────────────────────────────────────────────
# URL of the FastAPI backend as seen from the browser.
# Defaults to http://localhost:8000 if not set.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Port for the Next.js dev server.
FRONTEND_PORT=3000
